{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "palworld-guide-365",
  "compatibility_date": "2026-07-08",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "node scripts/build.js",
    "output_directory": "."
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
